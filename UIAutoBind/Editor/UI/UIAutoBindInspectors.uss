.uewt-root {
    padding-left: 8px;
    padding-top: 8px;
    padding-right: 18px;
    padding-bottom: 8px;
    min-width: 0;
}

.uewt-title {
    font-size: 15px;
    -unity-font-style: bold;
    margin-bottom: 6px;
    white-space: normal;
}

.uewt-section {
    border-width: 1px;
    border-color: #3f3f3f;
    border-radius: 4px;
    padding: 7px;
    margin-bottom: 7px;
    background-color: #242424;
    min-width: 0;
}

.uewt-section-title {
    -unity-font-style: bold;
    margin-bottom: 4px;
}

.uewt-toolbar {
    flex-direction: row;
    flex-wrap: wrap;
    margin-bottom: 7px;
    min-width: 0;
}

.uewt-toolbar-button {
    min-width: 86px;
    margin-right: 4px;
    margin-bottom: 4px;
}

.uewt-row {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 4px;
    min-width: 0;
}

.uewt-root .unity-base-field {
    min-width: 0;
}

.uewt-root .unity-base-field__input {
    flex-shrink: 1;
    min-width: 0;
}

.uewt-root .unity-object-field__selector {
    flex-shrink: 0;
}

.uewt-grow {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
}

.uewt-small-button {
    min-width: 70px;
    flex-shrink: 0;
    margin-left: 4px;
}

.uewt-bind-section {
    min-height: 180px;
}

.uewt-scroll {
    min-height: 160px;
    min-width: 0;
}

.uewt-bind-row {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 4px;
    min-width: 0;
}

.uewt-index-label {
    width: 32px;
    flex-shrink: 0;
}

.uewt-name-field {
    width: 170px;
    min-width: 96px;
    flex-shrink: 1;
    margin-right: 4px;
}

.uewt-component-field {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 180px;
}

.uewt-danger-button {
    width: 32px;
    flex-shrink: 0;
    margin-left: 4px;
}

.uewt-help {
    white-space: normal;
    color: #ff9c7a;
}
